  },
  {
   "id": "impuls-legeme",
   "type": "begreb",
   "navn": "Impuls & bevægelsesmængde (stift legeme)",
   "resume": "Lineær: m·v_G; vinkel: H_G = I_G·ω. Impuls-princippet kobler kraft/moment over tid til ændringer.",
