   "fag": "dyn2"
  },
  {
   "id": "centralkraft",
   "type": "begreb",
   "navn": "Centralkraftbevægelse",
   "resume": "Bevægelse under central kraft (satellitbaner, Kepler); impulsmoment bevaret.",
   "fag": "dyn2"
  },
  {
   "id": "arbejde",
   "type": "begreb",
   "navn": "En krafts arbejde",
   "resume": "U = ∫F·dr; arbejde af konstant kraft, tyngde og fjeder er standard-tilfældene.",
   "fag": "dyn2"
  },
  {
   "id": "arbejde-energi-partikel",
   "type": "begreb",
   "navn": "Arbejds-energi-princippet (partikel)",
   "resume": "T₁ + ΣU₁₋₂ = T₂ med T=½mv². Integreret form af Newtons 2. lov — omgår acceleration.",
   "fag": "dyn2"
  },
  {
   "id": "effekt-virkningsgrad",
   "type": "begreb",
   "navn": "Effekt og virkningsgrad",
   "resume": "P = dU/dt = F·v; ε = P_ud/P_ind. Motor- og maskinedimensionering.",
   "fag": "dyn2"
  },
  {
   "id": "potentiel-energi",
   "type": "begreb",
   "navn": "Konservative kræfter & potentiel energi",
   "resume": "V_g = W·y og V_e = ½ks²; en krafts arbejde uafhængigt af vejen ⇒ konservativ.",
   "fag": "dyn2"
  },
  {
   "id": "energibevarelse",
   "type": "begreb",
   "navn": "Energibevarelse",
   "resume": "T₁+V₁ = T₂+V₂ når kun konservative kræfter udfører arbejde.",
   "fag": "dyn2"
  },
  {
   "id": "lineaer-impuls",
   "type": "begreb",
   "navn": "Lineær impuls & bevægelsesmængde",
   "resume": "m·v₁ + Σ∫F dt = m·v₂. Tidsintegreret form af Newtons 2. lov — stærk ved kraft-tid-problemer.",
   "fag": "dyn2"
  },
  {
   "id": "bevarelse-bevaegelsesmaengde",
   "type": "begreb",
   "navn": "Bevarelse af bevægelsesmængde",
   "resume": "Σm·v = konstant når ydre impulser er nul/ubetydelige — nøglen til stødproblemer.",
   "fag": "dyn2"
  },
  {
   "id": "stoed",
   "type": "begreb",
   "navn": "Stød (stødtal e)",
   "resume": "Centralt/skævt stød; e = relativ separationshastighed / relativ tilnærmelseshastighed (0=plastisk, 1=elastisk).",
   "fag": "dyn2"
  },
  {
   "id": "impulsmoment",
   "type": "begreb",
   "navn": "Impulsmoment (partikel)",
   "resume": "H_O = r × m·v; ΣM_O = Ḣ_O. Vinkel-analogen til bevægelsesmængde.",
   "fag": "dyn2"
  },
  {
   "id": "translation-rotation",
   "type": "begreb",
   "navn": "Translation & rotation om fast akse",
   "resume": "ω=dθ/dt, α=dω/dt; v=ωr, a_t=αr, a_n=ω²r. Stiflegeme-kinematikkens byggesten.",
   "fag": "dyn2"
  },
  {
   "id": "relativ-hastighed-legeme",
   "type": "begreb",
   "navn": "Relativ hastighedsanalyse",
   "resume": "v_B = v_A + ω × r_B/A for to punkter på samme stive legeme.",
   "fag": "dyn2"
  },
  {
   "id": "ic-center",
   "type": "begreb",
   "navn": "Øjeblikkeligt hastighedscenter (IC)",
   "resume": "Punktet med v=0; hele legemets hastighedsfelt er ren rotation om IC i øjeblikket.",
   "fag": "dyn2"
  },
  {
   "id": "relativ-acceleration-legeme",
   "type": "begreb",
   "navn": "Relativ accelerationsanalyse",
   "resume": "a_B = a_A + α × r_B/A − ω²·r_B/A; IC kan IKKE bruges direkte til acceleration.",
   "fag": "dyn2"
  },
  {
   "id": "massemoment-inerti",
   "type": "begreb",
   "navn": "Massemoment af inerti",
   "resume": "I = ∫r² dm; parallelakse-sætningen I = I_G + md². Rotationens \"masse\".",
   "fag": "dyn2"
  },
  {
   "id": "bevaegelsesligninger-legeme",
   "type": "begreb",
   "navn": "Bevægelsesligninger (stift legeme, plan)",
   "resume": "ΣF = m·a_G og ΣM_G = I_G·α (eller ΣM_O = I_O·α om fast akse) — for translation, rotation og generel planbevægelse.",
   "fag": "dyn2"
  },
  {
   "id": "kinetisk-energi-legeme",
   "type": "begreb",
   "navn": "Kinetisk energi (stift legeme)",
   "resume": "T = ½mv_G² + ½I_Gω² — translations- plus rotationsled.",
   "fag": "dyn2"
  },
  {
   "id": "arbejde-energi-legeme",
   "type": "begreb",
   "navn": "Arbejds-energi-princippet (stift legeme)",
   "resume": "T₁ + ΣU₁₋₂ = T₂ inkl. kraftpars arbejde U = ∫M dθ; energibevarelse ved konservative systemer.",
